{
  "name": "@serverlesskit/auth",
  "version": "0.1.0",
  "description": "Authentication and RBAC for ServerlessKit",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./types": {
      "types": "./dist/auth.types.d.ts",
      "import": "./dist/auth.types.js"
    },
    "./permissions": {
      "types": "./dist/permissions.d.ts",
      "import": "./dist/permissions.js"
    },
    "./rbac": {
      "types": "./dist/rbac.d.ts",
      "import": "./dist/rbac.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./config": {
      "types": "./dist/auth-config.d.ts",
      "import": "./dist/auth-config.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@serverlesskit/shared": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@biomejs/biome": "^1.9.4"
  }
}

{
  "name": "@serverlesskit/adapter-vercel",
  "version": "0.1.0",
  "description": "Vercel adapter for ServerlessKit",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@serverlesskit/shared": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@biomejs/biome": "^1.9.4"
  }
}

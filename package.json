{
  "name": "serverlesskit",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, serverless-first data management system",
  "license": "MIT",
  "author": "Md Nishath Khandakar",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "biome format --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.5.2",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3"
  }
}
